    <section class="review-party">
        <div class="container">
            <header class="review-party__header">
                <h2 class="review-party__header-title title title--h2 has-subtitle">{{ 'Independent Review party'|trans }}</h2>
                <p class="review-party__header-subtitle p p--secondary">{{ 'See how users all around the world rate SimplyBook.me compared to the other best appointment scheduling softwares.'|trans }}</p>
            </header>

            <div class="review-party__cards">
                {% for item in review_data %}
                    <div class="review-party__card">
                        <div class="review-party__card-header">
                            <h3 class="review-party__card-header-title title title--h3">{{ item.title|trans }}</h3>
                            <div class="review-party__card-header-rating">{% if item.is_stars_based is same as(true) %}<img src="{{ asset('build/images/icons/stars-row.svg') }}" alt="Stars icon" />{% else %} <p class="p p--secondary p--small">{{ item.is_stars_based|trans }}</p> {% endif %}</div>
                        </div>
                        <ul class="review-party__card-list">
                            <li class="review-party__card-item">
                                <p class="review-party__card-item-title p p--bold">{{ item.value_1_title|trans}}</p>
                                <p class="review-party__card-item-rate p p--bold highlight">{{ item.value_1 }}</p>
                                <p class="review-party__card-item-reviews p p--small">({{ item.value_1_reviews }} {{ 'reviews'|trans }})</p>
                            </li>
                            <li class="review-party__card-item">
                                <p class="review-party__card-item-title p p--bold">{{ item.value_2_title|trans}}</p>
                                <p class="review-party__card-item-rate p p--bold highlight">{{ item.value_2 }}</p>
                                <p class="review-party__card-item-reviews p p--small">({{ item.value_2_reviews }} {{ 'reviews'|trans }})</p>
                            </li>
                            <li class="review-party__card-item">
                                <p class="review-party__card-item-title p p--bold">{{ item.value_3_title|trans}}</p>
                                <p class="review-party__card-item-rate p p--bold highlight">{{ item.value_3 }}</p>
                                <p class="review-party__card-item-reviews p p--small">({{ item.value_3_reviews }} {{ 'reviews'|trans }})</p>
                            </li>
                            <li class="review-party__card-item">
                                <p class="review-party__card-item-title p p--bold">{{ item.value_4_title|trans}}</p>
                                <p class="review-party__card-item-rate p p--bold highlight">{{ item.value_4 }}</p>
                                <p class="review-party__card-item-reviews p p--small">({{ item.value_4_reviews }} {{ 'reviews'|trans }})</p>
                            </li>
                        </ul>
                    </div>
                {% endfor %}
            </div>

            <div class="compare-table compare-table--reviews">
                <div class="compare-table__row compare-table__row--first">
                    <div class="compare-table__column compare-table__column--first">
                        <p class="compare-table__column-title title title--h3">{{ 'Review party'|trans }}</p>
                    </div>
                    <div class="compare-table__column compare-table__column--colored">
                        <p class="compare-table__column-title p p--bold">{{ 'SimplyBook.me'|trans }}</p>
                    </div>
                    <div class="compare-table__column">
                        <p class="compare-table__column-title p p--bold">{{ 'Setmore'|trans }}</p>
                    </div>
                    <div class="compare-table__column compare-table__column--colored">
                        <p class="compare-table__column-title p p--bold">{{ 'Calendly'|trans }}</p>
                    </div>
                    <div class="compare-table__column">
                        <p class="compare-table__column-title p p--bold">{{ 'Acuity Scheduling'|trans }}</p>
                    </div>
                </div>
                {% for item in review_data %}
                    <div class="compare-table__row">
                        <div class="compare-table__column compare-table__column--first"><p class="p p--small">{{ item.title|trans }}</p>{% if item.is_stars_based is same as(true) %}<img src="{{ asset('build/images/icons/stars-row.svg') }}" class="compare-table__column-rating" alt="Stars row image" />{% else %}<div class="compare-table__column-rating p p--secondary p--small">{{ item.is_stars_based|trans }}</div>{% endif %}</div>
