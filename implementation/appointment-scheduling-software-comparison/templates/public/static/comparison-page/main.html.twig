                            <p class="compare-table__column-title p p--bold highlight">{{ item.value_1|trans }}</p>
                            <p class="compare-table__column-title p p--small">({{ item.value_1_reviews }} {{ 'reviews'|trans }})</p>
                        </div>
                        <div class="compare-table__column">
                            <p class="compare-table__column-title p p--bold highlight">{{ item.value_2|trans }}</p>
                            <p class="compare-table__column-title p p--small">({{ item.value_2_reviews }} {{ 'reviews'|trans }})</p>
                        </div>
                        <div class="compare-table__column compare-table__column--colored">
                            <p class="compare-table__column-title p p--bold highlight">{{ item.value_3|trans }}</p>
                            <p class="compare-table__column-title p p--small">({{ item.value_3_reviews }} {{ 'reviews'|trans }})</p>
                        </div>
                        <div class="compare-table__column compare-table__column">
