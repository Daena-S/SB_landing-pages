                        <p class="compare-cover__header-subtitle p">{{ 'Don´t take our word for it - see for yourself what customers are saying about SimplyBook.me'|trans }}</p>
                    </section>
                    <picture class="compare-item compare-item__picture">
                        <img width="1288" height="1028" loading="lazy" src="{{ asset('build/images/comparison-page/sb-comparison--hero.png') }}" alt="Simplybook best Appointment Scheduling Softwares"/>
                    </picture>
                </div>
            </article>
        </div>
    </section>

    <section class="compare-features">
